{
  "appId": "com.kworkparser.app",
  "appName": "Kwork Лента",
  "webDir": "www",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https",
    "allowNavigation": [
      "kwork.ru",
      "*.kwork.ru"
    ]
  },
  "android": {
    "allowMixedContent": true
  },
  "plugins": {
    "CapacitorHttp": {
      "enabled": true
    },
    "SplashScreen": {
      "launchShowDuration": 600,
      "backgroundColor": "#0a0a0c",
      "showSpinner": false
    }
  }
}
